# =============================================================================
# EduRAG Causal AI — Environment Variables (example)
# Copy this file to `.env` and fill in values. Never commit the real `.env`.
# =============================================================================

# --- Application ---
NODE_ENV=development
APP_NAME=EduRAG
APP_URL=http://localhost:3000

# --- Database (Postgres-only as of the Phase 12B/12C correction) ---
#
# Prisma 5.x does not support an env-driven `provider` field, so we are
# locked to Postgres. Local dev runs against the Postgres service in
# docker-compose.yml; production runs against Neon (Vercel-hosted).
#
# Local dev defaults assume `docker compose up -d db` is running. The
# password below MUST match POSTGRES_PASSWORD — they are interpolated
# into both the compose env and DATABASE_URL.
POSTGRES_USER=edurag
POSTGRES_PASSWORD=edurag_local_password
POSTGRES_DB=edurag
DATABASE_URL="postgresql://edurag:edurag_local_password@localhost:5432/edurag?schema=public"
# DIRECT_URL only matters when DATABASE_URL points at a connection pooler
# (Neon, PgBouncer). Locally it is identical to DATABASE_URL.
DIRECT_URL="postgresql://edurag:edurag_local_password@localhost:5432/edurag?schema=public"

# Production / Vercel + Neon — paste the pooler URL into DATABASE_URL and
# the direct URL into DIRECT_URL (commented examples below):
# DATABASE_URL="postgresql://USER:PASS@HOST-pooler.us-east-1.aws.neon.tech/edurag?sslmode=require&pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://USER:PASS@HOST.us-east-1.aws.neon.tech/edurag?sslmode=require"

# --- Python Causal Engine (FastAPI service, if used) ---
# Optional separate process for heavy causal computation.
CAUSAL_ENGINE_URL=http://localhost:8000
CAUSAL_ENGINE_API_KEY=

# --- Demo mode (Phase 12C — gates hosted-only safety rails) ---
# `local` (default) renders the app as-is. `hosted` enables the public-demo
# banner, the upload row-cap guard, and the nightly-reseed messaging.
DEMO_MODE=local

# Public origin used by robots.ts + report download links. Override on
# Vercel to the assigned hostname (e.g. https://edurag.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required on Vercel — gates the destructive POST /api/admin/reseed
# endpoint that the daily cron invokes. Generate with `openssl rand
# -hex 32` and paste into the Vercel project env. Leave UNSET locally;
# the route returns 503 ("not configured") when the var is missing.
# CRON_SECRET=

# --- Feature Flags ---
ENABLE_WHAT_IF_SIMULATOR=true
ENABLE_DATASET_UPLOAD=true
# Set to "false" to skip optional Python engine probes (e.g. on CI runners
# without a Python interpreter installed).
ENABLE_PYTHON_ENGINE=true

# --- Logging ---
LOG_LEVEL=info
