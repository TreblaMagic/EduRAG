# =============================================================================
# EduRAG Causal AI — Environment Variables (example)
# Copy this file to `.env` and fill in values. Never commit the real `.env`.
# =============================================================================

# --- Application ---
NODE_ENV=development
APP_NAME=EduRAG
APP_URL=http://localhost:3000

# --- Database (SQLite for MVP, migratable to PostgreSQL later) ---
# Prisma URL form. For Postgres: postgresql://user:pass@host:5432/edurag
DATABASE_URL="file:./prisma/dev.db"

# --- Python Causal Engine (FastAPI service, if used) ---
# Optional separate process for heavy causal computation.
CAUSAL_ENGINE_URL=http://localhost:8000
CAUSAL_ENGINE_API_KEY=

# --- Feature Flags ---
ENABLE_WHAT_IF_SIMULATOR=true
ENABLE_DATASET_UPLOAD=true

# --- Logging ---
LOG_LEVEL=info
