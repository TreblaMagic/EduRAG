{
  "name": "edurag-causal-ai",
  "version": "0.1.0",
  "private": true,
  "description": "EduRAG — Explainable Causal AI for student success analytics.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:seed": "prisma db seed",
    "data:generate": "python scripts/generate_synthetic_dataset.py",
    "setup": "tsx src/server/bootstrap/setup-cli.ts",
    "demo": "tsx src/server/bootstrap/demo-cli.ts",
    "reset:demo": "tsx src/server/bootstrap/reset-cli.ts",
    "doctor": "tsx src/server/bootstrap/doctor-cli.ts",
    "status": "tsx src/server/bootstrap/status-cli.ts",
    "db:ingest": "tsx src/server/ingest/cli.ts",
    "causal:estimate": "tsx src/server/causal/cli.ts",
    "causal:simulate": "tsx src/server/causal/simulate-cli.ts",
    "causal:discover": "tsx src/server/causal/discover-cli.ts",
    "causal:report": "tsx src/server/causal/report-cli.ts",
    "ml:predict": "tsx src/server/prediction/cli.ts",
    "shell:seed": "tsx src/features/shell-university/seed-cli.ts",
    "sync:university": "tsx src/server/sync/shell-university/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "csv-parse": "^5.5.6",
    "next": "^15.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
