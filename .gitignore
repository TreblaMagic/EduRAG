coverage/
*.lcov
.nyc_output/

# Databases (local SQLite)
*.db
*.sqlite
*.sqlite3
prisma/*.db
prisma/*.db-journal

# Data (keep folders, ignore contents)
data/raw/*
!data/raw/.gitkeep
# Phase 12B: ship the bounded synthetic CSV so the Vercel build's
# `prisma db seed` step has a deterministic source. Local devs can
# still regenerate via `npm run data:generate`.
!data/raw/sample_lms_data.csv
data/processed/*
!data/processed/.gitkeep
data/shell-university/*
!data/shell-university/.gitkeep
# Phase 12B: commit the seeded Shell University JSON so the hosted
# demo's mock LMS works against a sealed bundle (no FS writes at
# runtime). Re-seed locally with `npm run shell:seed`.
!data/shell-university/*.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local Claude / agent runtime
.claude/local/
